; Supply-chain hardening — see gridcoin.club family-wide policy.
; ignore-scripts blocks lifecycle scripts (postinstall, preinstall, etc.)
; on every npm install / npm ci, including in CI and Docker builds. The
; usual culprits (Prisma's auto-generate, sharp's binary download, husky's
; hook setup) are invoked explicitly from prebuild/predev/prepare scripts
; instead, so a compromised transitive dep can't run code at install time.
ignore-scripts=true
audit-level=high
fund=false
