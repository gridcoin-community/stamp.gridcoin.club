{
  "ts-node": {
    "compilerOptions": {
      "resolveJsonModule": true
    }
  },
  "compilerOptions": {
    "target": "es2019",
    "module": "commonjs",
    "outDir": "./dist",
    "allowJs": true,
    "resolveJsonModule": false,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "sourceMap": false,
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "useUnknownInCatchVariables": true,
    "strict": true
  },
  "include": [
    "src",
    "tests"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "scripts/*.ts",
    "./src/**/_*.ts"
  ]
}
